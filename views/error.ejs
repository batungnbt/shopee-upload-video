<style>
  .error-shell {
    min-height: calc(100vh - 120px);
    display: grid;
    place-items: center;
  }

  .error-card {
    width: min(760px, 100%);
    padding: 28px;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.86);
    border: 1px solid rgba(180, 35, 24, 0.14);
    box-shadow: 0 18px 34px rgba(15, 23, 42, 0.06);
  }

  .error-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border-radius: 999px;
    background: #fff3f2;
    color: #b42318;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .error-title {
    margin: 16px 0 10px;
    color: #111827;
    text-wrap: balance;
  }

  .error-copy {
    margin: 0;
    color: #6b7280;
    line-height: 1.7;
  }

  .error-meta {
    display: grid;
    gap: 10px;
    margin-top: 20px;
  }

  .error-box {
    padding: 14px 16px;
    border-radius: 18px;
    background: #fffaf9;
    border: 1px solid rgba(255, 130, 90, 0.12);
    color: #374151;
  }

  .error-box pre {
    white-space: pre-wrap;
    word-break: break-word;
    margin: 0;
    max-height: 260px;
    overflow: auto;
    font-size: 0.86rem;
  }

  .error-actions {
    margin-top: 22px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
</style>

<section class="error-shell">
  <div class="error-card">
    <span class="error-chip">
      <i class="fas fa-triangle-exclamation" aria-hidden="true"></i>
      Có lỗi xảy ra
    </span>

    <h1 class="error-title"><%= message %></h1>
    <p class="error-copy">Trang này hiện không khả dụng hoặc đã có lỗi khi xử lý yêu cầu. Bạn có thể quay lại trang chính để tiếp tục thao tác.</p>

    <div class="error-meta">
      <% if (error && error.status) { %>
        <div class="error-box">Mã trạng thái: <strong><%= error.status %></strong></div>
      <% } %>

      <% if (error && error.stack) { %>
        <div class="error-box">
          <pre><%= error.stack %></pre>
        </div>
      <% } %>
    </div>

    <div class="error-actions">
      <a href="/" class="btn btn-primary">Về trang chủ</a>
      <a href="javascript:history.back()" class="btn btn-outline-secondary">Quay lại</a>
    </div>
  </div>
</section>
