                                        <td>${product.clicks || '0'}</td>
                                        <td>${product.atc || '0'}</td>
                                        <td>
                                            <div>Placed: ${product.placed_orders || '0'}</div>
                                            <div>Items: ${product.placed_items_sold || '0'}</div>
                                            <div>Sales: ${product.placed_sales ? product.placed_sales.toLocaleString() + 'đ' : '0đ'}</div>
                                        </td>
                                        <td>
                                            <div>Orders: ${product.confirmed_orders || '0'}</div>
                                            <div>Items: ${product.confirmed_items_sold || '0'}</div>
                                            <div>Sales: ${product.confirmed_sales ? product.confirmed_sales.toLocaleString() + 'đ' : '0đ'}</div>
                                        </td>
                                     
                                        <td>
                                            <a href="${product.url || '#'}" target="_blank" class="btn btn-sm btn-primary">
                                                <i class="fas fa-external-link-alt"></i>
                                            </a>
                                        </td>
                                    </tr>
                                `;
