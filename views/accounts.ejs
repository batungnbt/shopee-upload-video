            }
          })
          .then(response => response.json())
          .then(data => {
            if (data.success) {
              // Update product count
              document.getElementById('productCount').textContent = `${data.products.length} sản phẩm`;

              // Populate products table
              const tableBody = document.getElementById('productsTableBody');
              if (data.products.length > 0) {
                tableBody.innerHTML = '';
                data.products.forEach((product, index) => {
                  tableBody.innerHTML += `
                                    <tr>
                                        <td>${index + 1}</td>
                                        <td> ${product?.cover_image ? `<img src="${product.cover_image }" alt="Cover Image" style="width: 80px; height: 80px; object-fit: cover; border-radius: 4px;">` : '   <span class="badge bg-secondary">No Image</span>'}</td>
                                        <td> ${product?.name ? (product.name.length > 40 ? product.name.slice(0, 37) + '…': product.name) : 'N/A'}</td>
