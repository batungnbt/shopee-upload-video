<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quản lý tài khoản Shopee</title>
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Font Awesome for icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />


  <style>
    body {
      background: transparent;
    }

    .table-responsive {
      overflow-x: auto;
    }

    .action-buttons .btn {
      margin-right: 5px;
    }

    .badge-live-mode {
      font-size: 0.8rem;
    }

    .modal-header {
      background-color: #f8f9fa;
    }

    .select2-container {
      width: 100% !important;
    }

    .select2-container--default .select2-selection--single {
      height: 38px;
      padding: 5px;
      border: 1px solid #ced4da;
    }

    .select2-container--default .select2-selection--single .select2-selection__arrow {
      height: 36px;
    }

    .select2-dropdown-open-search .select2-search {
      display: block !important;
    }

    .select2-container--open .select2-dropdown {
      margin-top: 0;
    }

    .select2-search__field:focus {
      outline: none;
      border-color: #80bdff;
      box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
    }
  </style>
</head>

<body>
  <%- contentFor('body') %>

  <div class="container-fluid app-page">
    <section class="app-hero">
      <span class="app-eyebrow">
        <i class="fas fa-store" aria-hidden="true"></i>
        Account Control
      </span>
      <h2>Quản lý tài khoản Shopee trong giao diện gọn và dễ quét hơn.</h2>
      <p>Xem nhanh trạng thái tài khoản, phiên live, trạng thái stream và thao tác hàng loạt mà không phải dò qua nhiều khối giao diện nhỏ.</p>
      <div class="hero-actions">
        <button class="btn btn-light" data-bs-toggle="modal" data-bs-target="#addAccountModal">
          <i class="fas fa-plus" aria-hidden="true"></i> Add New Account
        </button>
      </div>
    </section>

    <!-- Filters and Search -->
    <div class="card surface-card">
      <div class="card-body">
    <div class="row g-2 mb-0 align-items-center">
      <% if (locals.isAdmin && locals.teams && locals.teams.length > 0) { %>
      <div class="col-auto">
        <select class="form-select" id="teamFilter" name="team" onchange="applyFilters()" style="min-width: 150px;">
          <option value="">All Teams</option>
          <% teams.forEach(team => { %>
          <option value="<%= team._id %>" <%= selectedTeam === team._id.toString() ? 'selected' : '' %>><%= team.name %></option>
          <% }); %>
        </select>
      </div>
      <% } %>
      <div class="col-auto">
        <select class="form-select" id="statusFilter" onchange="applyFilters()" style="min-width: 120px;">
          <option value="">All Status</option>
          <option value="true">Active</option>
          <option value="false">Inactive</option>
        </select>
      </div>
      <div class="col-auto">
        <a href="/shopee-accounts" class="btn btn-primary" title="Hiển thị tất cả">
          <i class="fas fa-sync-alt"></i> <span class="d-none d-xl-inline">All</span>
        </a>
      </div>
      <div class="col-auto">
        <button class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#filterAllAccountsModal" title="Filter All Accounts">
          <i class="fas fa-filter"></i> <span class="d-none d-xl-inline">Scan</span>
        </button>
      </div>
      <div class="col-auto">
        <button class="btn btn-info" data-bs-toggle="modal" data-bs-target="#batchUpdateMcnModal" title="Batch MCN Update">
          <i class="fas fa-users-cog"></i> <span class="d-none d-xl-inline">MCN</span>
        </button>
      </div>
      <div class="col-auto">
        <form id="searchForm" method="GET" action="/shopee-accounts" style="width: 300px;">
          <div class="input-group">
            <input type="text" class="form-control" placeholder="Search..." id="searchInput" name="search" value="<%= locals.search || '' %>">
            <button class="btn btn-outline-secondary" type="submit">
              <i class="fas fa-search"></i>
            </button>
            <a href="/shopee-accounts" class="btn btn-outline-secondary">
              <i class="fas fa-times"></i>
            </a>
          </div>
          <% if (locals.selectedTeam) { %>
          <input type="hidden" name="team" value="<%= selectedTeam %>">
          <% } %>
        </form>
      </div>
    </div>
      </div>
    </div>



    <!-- Bulk Actions Bar -->
    <div class="row mb-3" id="bulkActionsBar" style="display: none;">
      <div class="col">
        <div class="d-flex align-items-center">
          <span class="me-3">
            <span id="selectedCount">0</span> accounts selected
          </span>
          <button class="btn btn-danger btn-sm" id="bulkDeleteBtn">
            <i class="fas fa-trash"></i> Delete Selected
          </button>
          <button class="btn btn-secondary btn-sm ms-2" id="clearSelectionBtn">
            <i class="fas fa-times"></i> Clear Selection
          </button>
        </div>
      </div>
    </div>

    <!-- Accounts Table -->
    <div class="card surface-card data-table-card">
      <div class="card-header">
        <div class="section-heading">
          <div>
            <h5 class="mb-0">Danh sách tài khoản</h5>
            <p><%= accounts.length %> tài khoản trên màn hình hiện tại.</p>
          </div>
        </div>
      </div>
      <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-striped table-hover" id="accountsTable">
        <thead class="table-light">
          <tr>
            <th>
              <input type="checkbox" id="selectAll" class="form-check-input">
            </th>
            <th>STT</th>
            <th>Shop ID</th>
            <th>Username</th>
            <th>Email</th>
            <% if (locals.isAdmin) { %><th>Team</th><% } %>
            <th>Status</th>
            <th>Products</th>
            <th>Created At</th>
            <th>State</th>
            <th>Stream Status</th>
            <th>Session Live</th>
            <th>Video</th>
            <th>Is MCN</th>
            <th>Actions</th>
          </tr>
        </thead>
        <% accounts.forEach(( account, index) => { %>
        <tr data-account-id="<%= account._id %>">
          <td>
            <input type="checkbox" class="form-check-input account-checkbox" data-account-id="<%= account._id %>" data-username="<%= account.username %>">
          </td>
          <td><%=index + 1 %></td>
          <td><%= account.shop_id || 'N/A' %></td>
          <td><%= account.username || 'N/A' %></td>
          <td><%= account.email || 'N/A' %></td>
          <% if (locals.isAdmin) { %>
          <td><%= account.team ? account.team.name : 'N/A' %></td>
          <% } %>
          <td>
            <% if(account.is_active) { %>
            <span class="badge bg-success">Active</span>
            <% } else { %>
            <span class="badge bg-danger">Inactive</span>
            <% } %>
          </td>

          <td>
            <%= account.productCount ? account.productCount : 'N/A' %>
          </td>
          <td><%= new Date(account.createdAt).toLocaleDateString() %></td>

          <td>
            <% if(account.state == "start") { %>
            <span class="badge bg-success">Live</span>
            <% } else if(account.state == "end") { %>
            <span class="badge bg-danger">End</span>
            <% } %>
          </td>
          <td class="stream-status" data-account-id="<%= account._id %>">
            <% if(account.state == "start") { %>
              <span class="badge bg-success stream-badge">Streaming</span>
            <% } else if(account.state == "error") { %>
              <span class="badge bg-danger stream-badge">Error</span>
            <% } else { %>
              <span class="badge bg-secondary stream-badge">Offline</span>
            <% } %>
          </td>
          <td><%= account.session_id || 'N/A' %></td>
          <td>
            <select class="form-select form-select-sm video-selector" data-account-id="<%= account._id %>" style="width: 120px;">
              <option value="">Chọn video</option>
            </select>
            <% if(account.videoFile) { %>
            <small class="text-muted d-block"><%= account.videoFile %></small>
            <% } %>
          </td>
          <td>
            <!-- Display Is MCN status -->
            <% if(account.isMcn) { %>
            <span class="badge bg-info">MCN</span>
            <% } else { %>
            <span class="badge bg-secondary">No</span>
            <% } %>
          </td>

          <td class="action-buttons">
            <a href="/shopee-accounts/setup-live/<%= account._id %>" class="btn btn-sm btn-info">
              <i class="fas fa-cog"></i>
            </a>
            <% if(account.state == "end" || !account.state) { %>
            <button class="btn btn-sm btn-success start-live" data-id="<%= account._id %>" data-username="<%= account.username %>" title="Start Live">
              <i class="fas fa-play"></i>
            </button>
            <% } else if(account.state == "start") { %>
            <button class="btn btn-sm btn-danger end-live" data-id="<%= account._id %>" data-username="<%= account.username %>" title="End Live">
              <i class="fas fa-stop"></i>
            </button>
            <% } %>
            <button class="btn btn-sm btn-primary filter-products" data-username="<%= account.username %>" title="Lấy Thông Tin Giỏ">
              <i class="fas fa-filter"></i>
            </button>
            <button class="btn btn-sm btn-success view-products" data-id="<%= account._id %>" data-username="<%= account.username %>" title="Xem sản phẩm">
              <i class="fas fa-box-open"></i>
            </button>
            <button class="btn btn-sm btn-info add-products-by-link" data-id="<%= account._id %>" data-username="<%= account.username %>" title="Thêm sản phẩm theo link">
              <i class="fas fa-link"></i>
            </button>
            <button class="btn btn-sm btn-warning edit-account" data-bs-toggle="modal" data-bs-target="#editAccountModal" data-id="<%= account._id %>" data-username="<%= account.username %>" data-email="<%= account.email %>" data-phone="<%= account.phone %>" data-shop-id="<%= account.shop_id %>" data-team="<%= account.team %>" data-is-active="<%= account.is_active %>" data-is-mcn="<%= account.isMcn %>">
              <i class="fas fa-edit"></i>
            </button>
            <button class="btn btn-sm btn-secondary transfer-products" data-id="<%= account._id %>" data-username="<%= account.username %>" title="Chuyển sản phẩm">
              <i class="fas fa-exchange-alt"></i>
            </button>
            <button class="btn btn-sm btn-danger delete-account" data-id="<%= account._id %>" data-username="<%= account.username %>">
              <i class="fas fa-trash"></i>
            </button>
          </td>
        </tr>
        <% }); %>
        </tbody>
      </table>
    </div>
      </div>
    </div>

   
  </div>
  <!-- Add Products By Link Modal -->
  <div class="modal fade" id="addProductsByLinkModal" tabindex="-1" aria-labelledby="addProductsByLinkModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="addProductsByLinkModalLabel">Thêm sản phẩm theo link cho <span id="addProductsAccountName" class="fw-bold"></span></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label for="productLinks" class="form-label">Nhập link sản phẩm (mỗi link một dòng)</label>
            <textarea class="form-control" id="productLinks" rows="10" placeholder="<%= ((process.env.SHOPEE_ORIGIN || 'https://shopee.vn').startsWith('http') ? (process.env.SHOPEE_ORIGIN || 'https://shopee.vn') : `https://${process.env.SHOPEE_ORIGIN || 'shopee.vn'}`) %>/product/158647903/2403800575&#10;<%= ((process.env.SHOPEE_ORIGIN || 'https://shopee.vn').startsWith('http') ? (process.env.SHOPEE_ORIGIN || 'https://shopee.vn') : `https://${process.env.SHOPEE_ORIGIN || 'shopee.vn'}`) %>/product/123456789/9876543210"></textarea>
          </div>
          <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> Mỗi link sản phẩm nhập trên một dòng mới. Ví dụ: <%= ((process.env.SHOPEE_ORIGIN || 'https://shopee.vn').startsWith('http') ? (process.env.SHOPEE_ORIGIN || 'https://shopee.vn') : `https://${process.env.SHOPEE_ORIGIN || 'shopee.vn'}`) %>/product/158647903/2403800575
          </div>
          <div class="mt-2">
            <p>Tổng số link đã nhập: <span id="linkCount" class="fw-bold">0</span></p>
          </div>
          <div class="progress d-none" id="addProductsProgress">
            <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%"></div>
          </div>
          <div id="addProductsResults" class="mt-3"></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
          <button type="button" class="btn btn-primary" id="confirmAddProducts">Thêm sản phẩm</button>
        </div>
      </div>
    </div>
  </div>
  <!-- Add Account Modal -->
  <div class="modal fade" id="addAccountModal" tabindex="-1" aria-labelledby="addAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="addAccountModalLabel">Add New Account</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form action="/shopee-accounts/add" method="POST">
          <div class="modal-body">
            <div class="mb-3">
              <label for="username" class="form-label">Username</label>
              <input type="text" class="form-control" id="username" name="username" required>
            </div>
            <div class="mb-3">
              <label for="email" class="form-label">Email</label>
              <input type="email" class="form-control" id="email" name="email">
            </div>
            <div class="mb-3">
              <label for="phone" class="form-label">Phone</label>
              <input type="text" class="form-control" id="phone" name="phone">
            </div>
            <div class="mb-3">
              <label for="shop_id" class="form-label">Shop ID</label>
              <input type="text" class="form-control" id="shop_id" name="shop_id">
            </div>
            <div class="mb-3">
              <% if (locals.isAdmin && locals.teams && locals.teams.length > 0) { %>
              <div class="mb-3">
                <label for="team" class="form-label">Team</label>
                <select class="form-select" id="team" name="team">
                  <option value="">Select Team</option>
                  <% teams.forEach(team => { %>
                  <option value="<%= team._id %>"><%= team.name %></option>
                  <% }); %>
                </select>
              </div>
              <% } else if (locals.user && locals.user.team) { %>
              <input type="hidden" name="team" value="<%= locals.user.team %>">
              <% } %>
            </div>
            <div class="form-check mb-3">
              <input class="form-check-input" type="checkbox" id="is_active" name="is_active" checked>
              <label class="form-check-label" for="is_active">
                Active
              </label>
            </div>
            <div class="form-check mb-3">
              <input class="form-check-input" type="checkbox" id="isMcn" name="isMcn">
              <label class="form-check-label" for="isMcn">
                Is MCN
              </label>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Add Account</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Batch Update MCN Status Modal -->
  <div class="modal fade" id="batchUpdateMcnModal" tabindex="-1" aria-labelledby="batchUpdateMcnModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="batchUpdateMcnModalLabel">Batch Update MCN Status</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label for="mcnStatus" class="form-label">Set MCN Status</label>
            <select class="form-select" id="mcnStatus">
              <option value="true">Enable MCN</option>
              <option value="false">Disable MCN</option>
            </select>
          </div>
          <div class="mb-3">
            <label for="usernameList" class="form-label">Enter Usernames (one per line)</label>
            <textarea class="form-control" id="usernameList" rows="10" placeholder="username1&#10;username2&#10;username3"></textarea>
          </div>
          <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> Enter each username on a new line. The MCN status will be updated for all matching accounts.
          </div>
          <div id="batchUpdateResults" class="mt-3"></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-primary" id="confirmBatchUpdate">Update Accounts</button>
        </div>
      </div>
    </div>
  </div>
  <!-- Edit Account Modal -->
  <div class="modal fade" id="editAccountModal" tabindex="-1" aria-labelledby="editAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="editAccountModalLabel">Edit Account</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form id="editAccountForm" method="POST">
          <div class="modal-body">
            <div class="mb-3">
              <label for="edit_username" class="form-label">Username</label>
              <input type="text" class="form-control" id="edit_username" name="username" required>
            </div>
            <div class="mb-3">
              <label for="edit_email" class="form-label">Email</label>
              <input type="email" class="form-control" id="edit_email" name="email">
            </div>
            <div class="mb-3">
              <label for="edit_phone" class="form-label">Phone</label>
              <input type="text" class="form-control" id="edit_phone" name="phone">
            </div>
            <div class="mb-3">
              <label for="edit_shop_id" class="form-label">Shop ID</label>
              <input type="text" class="form-control" id="edit_shop_id" name="shop_id">
            </div>
            <div class="mb-3">
              <% if (locals.isAdmin && locals.teams && locals.teams.length > 0) { %>
              <div class="mb-3">
                <label for="edit_team" class="form-label">Team</label>
                <select class="form-select" id="edit_team" name="team">
                  <option value="">Select Team</option>
                  <% teams.forEach(team => { %>
                  <option value="<%= team._id %>"><%= team.name %></option>
                  <% }); %>
                </select>
              </div>
              <% } %>
            </div>
            <div class="form-check mb-3">
              <input class="form-check-input" type="checkbox" id="edit_is_active" name="is_active">
              <label class="form-check-label" for="edit_is_active">
                Active
              </label>
            </div>
            <div class="form-check mb-3">
              <input class="form-check-input" type="checkbox" id="edit_isMcn" name="isMcn">
              <label class="form-check-label" for="edit_isMcn">
                Is MCN
              </label>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Save Changes</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-labelledby="deleteConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="deleteConfirmModalLabel">Confirm Delete</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p>Are you sure you want to delete the account <span id="deleteAccountName" class="fw-bold"></span>?</p>
          <p class="text-danger">This action cannot be undone.</p>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-danger" id="confirmDelete">Delete</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Bulk Delete Confirmation Modal -->
  <div class="modal fade" id="bulkDeleteConfirmModal" tabindex="-1" aria-labelledby="bulkDeleteConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="bulkDeleteConfirmModalLabel">Confirm Bulk Delete</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p>Are you sure you want to delete <span id="bulkDeleteCount" class="fw-bold"></span> selected accounts?</p>
          <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle"></i> This action cannot be undone. All selected accounts will be permanently deleted.
          </div>
          <div id="bulkDeleteAccountList" class="mt-3"></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-danger" id="confirmBulkDelete">Delete Selected Accounts</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Filter Products Modal -->
  <div class="modal fade" id="filterProductsModal" tabindex="-1" aria-labelledby="filterProductsModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="filterProductsModalLabel">Filter Products</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p>This will filter products for account <span id="filterAccountName" class="fw-bold"></span>.</p>
          <ul>
            <li>Sẽ lấy thông tin các sản phâm của giỏ trong 7 ngày.</li>
            <li>Nếu giỏ trống khi lấy thông tin giỏ sẽ tự lấy giỏ trước đấy.</li>
            <li>Nếu không đủ giỏ hiện tại thì sẽ tự thêm sản phẩm từ giỏ đã live trước đấy.</li>
          </ul>
          <div class="progress d-none" id="filterProgress">
            <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%"></div>
          </div>
          <div id="filterResults" class="mt-3"></div>
        </div>
        <div class="modal-footer">
