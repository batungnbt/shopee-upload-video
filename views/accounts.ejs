      // Batch Update MCN Status functionality
      const batchUpdateModal = new bootstrap.Modal(document.getElementById('batchUpdateMcnModal'));
      const confirmBatchUpdateBtn = document.getElementById('confirmBatchUpdate');

      if (confirmBatchUpdateBtn) {
        confirmBatchUpdateBtn.addEventListener('click', function() {
          // Get values from form
          const mcnStatus = document.getElementById('mcnStatus').value === 'true';
          const usernameListText = document.getElementById('usernameList').value.trim();

          if (!usernameListText) {
            document.getElementById('batchUpdateResults').innerHTML = `
           <div class="alert alert-warning">
             <p>Please enter at least one username.</p>
           </div>
         `;
            return;
          }

          // Parse usernames (split by newline and filter empty lines)
          const usernames = usernameListText.split('\n')
            .map(username => username.trim())
            .filter(username => username.length > 0);

          if (usernames.length === 0) {
            document.getElementById('batchUpdateResults').innerHTML = `
           <div class="alert alert-warning">
             <p>No valid usernames found.</p>
           </div>
         `;
            return;
          }

          // Disable button and show loading state
          this.disabled = true;
          this.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Updating...';

          // Prepare data for the request
          const requestData = {
            usernames: usernames,
            isMcn: mcnStatus
          };

          // Send the request to update accounts
          fetch('/shopee-accounts/batch-update-mcn', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify(requestData)
            })
            .then(response => response.json())
            .then(data => {
              // Re-enable button
              confirmBatchUpdateBtn.disabled = false;
              confirmBatchUpdateBtn.innerHTML = 'Update Accounts';

              if (data.success) {
                // Show success message with details
                document.getElementById('batchUpdateResults').innerHTML = `
             <div class="alert alert-success">
               <h5>Update Completed</h5>
               <p>Successfully updated ${data.updatedCount} out of ${usernames.length} accounts.</p>
               ${data.notFound.length > 0 ? 
                 `<p>The following usernames were not found:</p>
                 <ul>
                   ${data.notFound.map(username => `<li>${username}</li>`).join('')}
                 </ul>` : ''}
             </div>
             <button class="btn btn-primary" onclick="window.location.reload()">
               <i class="fas fa-sync"></i> Refresh Page
             </button>
           `;
              } else {
                // Show error message
                document.getElementById('batchUpdateResults').innerHTML = `
             <div class="alert alert-danger">
               <h5>Error</h5>
               <p>${data.message || 'An error occurred while updating accounts.'}</p>
             </div>
           `;
              }
            })
            .catch(error => {
              console.error('Error:', error);

              // Re-enable button
              confirmBatchUpdateBtn.disabled = false;
              confirmBatchUpdateBtn.innerHTML = 'Update Accounts';

              // Show error message
              document.getElementById('batchUpdateResults').innerHTML = `
           <div class="alert alert-danger">
             <h5>Error</h5>
             <p>An unexpected error occurred while updating accounts.</p>
           </div>
         `;
            });
        });
      }
