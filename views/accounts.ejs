                ${response.results.failed.length ? `<br><i class="fas fa-times-circle text-danger"></i> Không thể thêm ${response.results.failed.length} sản phẩm.` : ''}
                ${response.results.duplicates.length? `<br><i class="fas fa-exclamation-triangle text-warning"></i> Trùng ${response.results.duplicates.length || 0} sản phẩm.` : ''}
              </div>
            `);
          },
          error: function(error) {
            $('#addProductsProgress').addClass('d-none');
            $('#addProductsResults').html(`
              <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i> Đã xảy ra lỗi khi thêm sản phẩm: ${error.responseJSON?.message || 'Lỗi không xác định'}
              </div>
            `);
          }
        });
      });

      // Xử lý nút xác nhận thêm sản phẩm
      $(document).on('click', '#confirmAddProducts', function() {
        const accountId = $(this).data('account-id');
        const text = $('#productLinks').val();
        const links = text.split('\n').filter(link => link.trim() !== '');

        if (links.length === 0) {
          alert('Vui lòng nhập ít nhất một link sản phẩm!');
          return;
        }

        // Hiển thị thanh tiến trình
        $('#addProductsProgress').removeClass('d-none');
        $('#addProductsResults').html('<div class="alert alert-info">Đang xử lý...</div>');

        // Gửi request lên server
        $.ajax({
          url: '/shopee-accounts/add-products',
          method: 'POST',
          contentType: 'application/json',
          data: JSON.stringify({
            accountId: accountId,
            productLinks: links
          }),
          success: function(response) {
            $('#addProductsProgress').addClass('d-none');
            $('#addProductsResults').html(`
              <div class="alert alert-success">
                <i class="fas fa-check-circle"></i> Đã thêm thành công ${response.addedCount || 0} sản phẩm.
                ${response.failedCount ? `<br>Không thể thêm ${response.failedCount} sản phẩm.` : ''}
              </div>
            `);
          },
          error: function(error) {
            $('#addProductsProgress').addClass('d-none');
            $('#addProductsResults').html(`
              <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i> Đã xảy ra lỗi khi thêm sản phẩm: ${error.responseJSON?.message || 'Lỗi không xác định'}
              </div>
            `);
          }
        });
      });
      // Transfer products functionality
      $(document).on('click', '.transfer-products', function() {
        const sourceAccountId = $(this).data('id');
        const sourceUsername = $(this).data('username');

        $('#sourceAccountName').text(sourceUsername);
        $('#targetAccount').val('');
        $('#transferResults').empty();
        $('#transferProgress').addClass('d-none');

        // Lưu sourceAccountId vào nút xác nhận
        $('#confirmTransfer').data('source-account-id', sourceAccountId);
        // ... existing code ...
       
        // Hiển thị modal
        $('#transferProductsModal').modal('show');
      });
      // Xử lý khi đóng modal chuyển sản phẩm
      $('#transferProductsModal').on('hidden.bs.modal', function() {
        // Destroy Select2 để tránh xung đột khi mở lại modal
        if ($('#targetAccount').data('select2')) {
          $('#targetAccount').select2('destroy');
        }
      });
      // Xử lý nút xác nhận chuyển sản phẩm
      $(document).on('click', '#confirmTransfer', function() {
        const sourceAccountId = $(this).data('source-account-id');
        const targetAccountId = $('#targetAccount').val();

        if (!targetAccountId) {
          alert('Vui lòng chọn tài khoản đích!');
          return;
        }

        if (!confirm('Bạn có chắc chắn muốn chuyển tất cả sản phẩm sang tài khoản đã chọn? Hành động này không thể hoàn tác.')) {
          return;
        }

        // Hiển thị thanh tiến trình
        $('#transferProgress').removeClass('d-none');
        $('#transferResults').html('<div class="alert alert-info">Đang xử lý...</div>');

        // Disable nút xác nhận
        $(this).prop('disabled', true);
        $(this).html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Đang chuyển...');

        // Gửi request lên server
        $.ajax({
          url: '/shopee-accounts/transfer-products',
          method: 'POST',
          contentType: 'application/json',
          data: JSON.stringify({
            sourceAccountId: sourceAccountId,
            targetAccountId: targetAccountId
          }),
          success: function(response) {
            $('#transferProgress').addClass('d-none');
            $('#transferResults').html(`
                    <div class="alert alert-success">
                      <i class="fas fa-check-circle"></i> ${response.message}
                    </div>
                    <button class="btn btn-primary" onclick="window.location.reload()">
                      <i class="fas fa-sync"></i> Làm mới trang
                    </button>
                  `);

            // Re-enable nút xác nhận
            $('#confirmTransfer').prop('disabled', false);
            $('#confirmTransfer').html('Chuyển sản phẩm');
          },
          error: function(error) {
            $('#transferProgress').addClass('d-none');
            $('#transferResults').html(`
                    <div class="alert alert-danger">
                      <i class="fas fa-exclamation-circle"></i> Đã xảy ra lỗi khi chuyển sản phẩm: ${error.responseJSON?.message || 'Lỗi không xác định'}
                    </div>
                  `);

            // Re-enable nút xác nhận
            $('#confirmTransfer').prop('disabled', false);
            $('#confirmTransfer').html('Chuyển sản phẩm');
          }
        });
      });

    // Stream status polling for real-time updates
    function updateStreamStatus(accountId, status) {
      const row = $(`tr[data-account-id="${accountId}"]`);
      const actionsCell = row.find('.action-buttons');
      const streamStatusCell = row.find('.stream-status');
      
      // Update stream status column
      let streamBadge = '';
      if (status.isActive) {
        streamBadge = '<span class="badge bg-success stream-badge">Streaming</span>';
      } else if (status.retryCount > 0) {
        streamBadge = `<span class="badge bg-warning stream-badge">Retrying (${status.retryCount})</span>`;
      } else {
        streamBadge = '<span class="badge bg-secondary stream-badge">Offline</span>';
      }
      streamStatusCell.html(streamBadge);
      
      // Update action buttons
      const startBtn = actionsCell.find('.start-live');
      const endBtn = actionsCell.find('.end-live');
      
      if (status.isActive) {
        // Show end button, hide start button
        if (startBtn.length) startBtn.remove();
        if (endBtn.length === 0) {
          actionsCell.prepend(`
            <button class="btn btn-sm btn-danger end-live" data-id="${accountId}" data-username="${row.find('.start-live').data('username') || row.find('.end-live').data('username')}" title="End Live">
              <i class="fas fa-stop"></i>
            </button>
          `);
        }
      } else {
        // Show start button, hide end button
        if (endBtn.length) endBtn.remove();
        if (startBtn.length === 0) {
          actionsCell.prepend(`
            <button class="btn btn-sm btn-success start-live" data-id="${accountId}" data-username="${row.find('.end-live').data('username') || row.data('username')}" title="Start Live">
              <i class="fas fa-play"></i>
            </button>
          `);
        }
      }
      
      // Re-attach event handlers for new buttons
      attachStreamButtonHandlers();
    }

    function attachStreamButtonHandlers() {
      // Start Live button handler
      $('.start-live').off('click').on('click', function() {
        const accountId = $(this).data('id');
        const username = $(this).data('username');
        
        
        
        if (confirm(`Bạn có chắc chắn muốn bắt đầu stream cho tài khoản ${username} với video ${videoPath}?`)) {
          $.ajax({
            url: `/shopee-accounts/start-live/${accountId}`,
            method: 'POST',
            contentType: 'application/json',
            data: null,
            success: function(response) {
              if (response.success) {
                alert(`✅ Stream started for ${username}`);
                // Immediately update status
                updateStreamStatus(accountId, { isActive: true, retryCount: 0 });
              } else {
                alert(`❌ Failed to start stream: ${response.message}`);
              }
            },
            error: function(error) {
              alert(`❌ Error starting stream: ${error.responseJSON?.message || 'Unknown error'}`);
            }
          });
        }
      });

      // End Live button handler
      $('.end-live').off('click').on('click', function() {
        const accountId = $(this).data('id');
        const username = $(this).data('username');
        
        if (confirm(`Bạn có chắc chắn muốn dừng stream cho tài khoản ${username}?`)) {
          $.ajax({
            url: `/shopee-accounts/end-live/${accountId}`,
            method: 'POST',
            contentType: 'application/json',
            success: function(response) {
              if (response.success) {
                alert(`⏹️ Stream ended for ${username}`);
                // Immediately update status
                updateStreamStatus(accountId, { isActive: false, retryCount: 0 });
              } else {
                alert(`❌ Failed to end stream: ${response.message}`);
              }
            },
            error: function(error) {
              alert(`❌ Error ending stream: ${error.responseJSON?.message || 'Unknown error'}`);
            }
          });
        }
      });
    }

    // Poll stream status every 5 seconds
    function pollStreamStatus() {
      const accountIds = [];
      $('#accountsTable tbody tr').each(function() {
        const accountId = $(this).data('account-id');
        if (accountId) accountIds.push(accountId);
      });

      if (accountIds.length === 0) return;

      // Get all active streams at once for efficiency
      $.ajax({
        url: '/shopee-accounts/active-streams',
        method: 'GET',
        success: function(response) {
          if (response.success) {
            const activeStreams = response.data.activeStreams;
            
            // Update all accounts
            accountIds.forEach(accountId => {
              const isActive = activeStreams.includes(accountId);
              const status = {
                isActive: isActive,
                retryCount: 0 // Will be enhanced later
              };
              updateStreamStatus(accountId, status);
            });
          }
        },
        error: function(error) {
          console.error('❌ Error polling stream status:', error);
        }
      });
    }

    // Initialize stream status polling
    function initializeStreamPolling() {
      // Initial status update
      pollStreamStatus();
      
      // Set up periodic polling every 5 seconds
      setInterval(pollStreamStatus, 5000);
    }

    // Load video files for selectors
    function loadVideoSelectors() {
      fetch('/shopee-accounts/videos')
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            const videoSelectors = document.querySelectorAll('.video-selector');
            videoSelectors.forEach(selector => {
              const currentValue = selector.value;
              selector.innerHTML = '<option value="">Chọn video</option>';
              
              data.data.forEach(video => {
                const option = document.createElement('option');
                option.value = video.filename;
                option.textContent = video.filename;
                option.selected = (video.filename === currentValue);
                selector.appendChild(option);
              });
            });
          }
        })
        .catch(error => {
          console.error('❌ Error loading video selectors:', error);
        });
    }

    // Handle video selector change
    $(document).on('change', '.video-selector', function() {
      const accountId = $(this).data('account-id');
      const videoFile = $(this).val();
      
      if (videoFile) {
        fetch(`/shopee-accounts/${accountId}/video`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ videoFile: videoFile })
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            // Show success notification
            const notification = $(`
              <div class="alert alert-success alert-sm" style="position: fixed; top: 20px; right: 20px; z-index: 9999; padding: 8px 12px; font-size: 12px;">
                Video đã được lưu: ${videoFile}
              </div>
            `);
            $('body').append(notification);
            setTimeout(() => notification.fadeOut(() => notification.remove()), 2000);
          } else {
            alert('Lỗi: ' + data.message);
            $(this).val(''); // Reset selector
          }
        })
        .catch(error => {
          console.error('❌ Error updating video:', error);
          alert('Đã xảy ra lỗi khi cập nhật video.');
          $(this).val(''); // Reset selector
        });
      }
    });

    // Attach handlers on page load
    $(document).ready(function() {
      attachStreamButtonHandlers();
      initializeStreamPolling();
      loadVideoSelectors();
    });

    // Load video files for selectors
    function loadVideoSelectors() {
