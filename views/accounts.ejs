              data.data.forEach(video => {
                const option = document.createElement('option');
                option.value = video.filename;
                option.textContent = video.filename;
                option.selected = (video.filename === currentValue);
                selector.appendChild(option);
              });
            });
          }
        })
        .catch(error => {
          console.error('❌ Error loading video selectors:', error);
        });
    }

    // Handle video selector change
    $(document).on('change', '.video-selector', function() {
      const accountId = $(this).data('account-id');
      const videoFile = $(this).val();
      
      if (videoFile) {
        fetch(`/shopee-accounts/${accountId}/video`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ videoFile: videoFile })
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            // Show success notification
            const notification = $(`
              <div class="alert alert-success alert-sm" style="position: fixed; top: 20px; right: 20px; z-index: 9999; padding: 8px 12px; font-size: 12px;">
                Video đã được lưu: ${videoFile}
              </div>
            `);
            $('body').append(notification);
            setTimeout(() => notification.fadeOut(() => notification.remove()), 2000);
          } else {
            alert('Lỗi: ' + data.message);
            $(this).val(''); // Reset selector
          }
        })
        .catch(error => {
          console.error('❌ Error updating video:', error);
          alert('Đã xảy ra lỗi khi cập nhật video.');
          $(this).val(''); // Reset selector
        });
      }
    });


  </script>
