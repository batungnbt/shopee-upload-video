        $.ajax({
          url: '/shopee-accounts/add-products',
          method: 'POST',
          contentType: 'application/json',
          data: JSON.stringify({
            accountId: accountId,
            productLinks: links
          }),
          success: function(response) {
            $('#addProductsProgress').addClass('d-none');
            $('#addProductsResults').html(`
