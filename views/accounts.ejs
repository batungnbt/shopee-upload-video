  <!-- Bootstrap and jQuery Scripts -->
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Search functionality
      const searchInput = document.getElementById('searchInput');
      if (searchInput) {
        searchInput.addEventListener('keyup', function() {
          const searchTerm = this.value.toLowerCase();
          const tableRows = document.querySelectorAll('tbody tr');

          tableRows.forEach(row => {
            const username = row.cells[1].textContent.toLowerCase();
            const email = row.cells[2].textContent.toLowerCase();
            const phone = row.cells[3].textContent.toLowerCase();

            if (username.includes(searchTerm) || email.includes(searchTerm) || phone.includes(searchTerm)) {
              row.style.display = '';
            } else {
              row.style.display = 'none';
            }
          });
        });
      }

      // Handle Custom Cart toggle
      $(document).on('change', '.toggle-custom-cart', function() {
        const username = $(this).data('username');
        const isCustomCart = $(this).prop('checked') ? "1" : "0";

        $.ajax({
          url: '/shopee-accounts/update-cart-custom',
          method: 'POST',
          data: {
            username: username,
            isCustomCart: isCustomCart
          },
          success: function(response) {
            if (response.success) {
              showToast('success', response.message);
            } else {
              showToast('error', response.message || 'Error updating custom cart status');
              // Revert the toggle if there was an error
              $(this).prop('checked', !$(this).prop('checked'));
            }
          },
          error: function(xhr) {
            const errorMsg = xhr.responseJSON?.message || 'Server error';
            showToast('error', errorMsg);
            // Revert the toggle if there was an error
            $(this).prop('checked', !$(this).prop('checked'));
          }
        });
      });

      // Bulk selection functionality
      const selectAllCheckbox = document.getElementById('selectAll');
      const accountCheckboxes = document.querySelectorAll('.account-checkbox');
      const bulkActionsBar = document.getElementById('bulkActionsBar');
      const selectedCountSpan = document.getElementById('selectedCount');
      const bulkDeleteBtn = document.getElementById('bulkDeleteBtn');
      const clearSelectionBtn = document.getElementById('clearSelectionBtn');
      const bulkDeleteModal = new bootstrap.Modal(document.getElementById('bulkDeleteConfirmModal'));
      const confirmBulkDeleteBtn = document.getElementById('confirmBulkDelete');

      // Update selected count and show/hide bulk actions bar
      function updateBulkActions() {
        const selectedCheckboxes = document.querySelectorAll('.account-checkbox:checked');
        const selectedCount = selectedCheckboxes.length;
        
        selectedCountSpan.textContent = selectedCount;
        
        if (selectedCount > 0) {
          bulkActionsBar.style.display = 'block';
        } else {
          bulkActionsBar.style.display = 'none';
        }
      }

      // Select all functionality
      selectAllCheckbox.addEventListener('change', function() {
        const isChecked = this.checked;
        accountCheckboxes.forEach(checkbox => {
          checkbox.checked = isChecked;
        });
        updateBulkActions();
      });

      // Individual checkbox change
      accountCheckboxes.forEach(checkbox => {
        checkbox.addEventListener('change', function() {
          // Update select all checkbox state
          const allChecked = document.querySelectorAll('.account-checkbox').length === document.querySelectorAll('.account-checkbox:checked').length;
          const someChecked = document.querySelectorAll('.account-checkbox:checked').length > 0;
          
          selectAllCheckbox.checked = allChecked;
          selectAllCheckbox.indeterminate = someChecked && !allChecked;
          
          updateBulkActions();
        });
      });

      // Clear selection
      clearSelectionBtn.addEventListener('click', function() {
        accountCheckboxes.forEach(checkbox => {
          checkbox.checked = false;
        });
        selectAllCheckbox.checked = false;
        selectAllCheckbox.indeterminate = false;
        updateBulkActions();
      });

      // Bulk delete button click
      bulkDeleteBtn.addEventListener('click', function() {
        const selectedCheckboxes = document.querySelectorAll('.account-checkbox:checked');
        const selectedCount = selectedCheckboxes.length;
        
        if (selectedCount === 0) {
          return;
        }

        // Update modal content
        document.getElementById('bulkDeleteCount').textContent = selectedCount;
        
        // Show list of accounts to be deleted
        
        bulkDeleteModal.show();
      });

      // Confirm bulk delete
      confirmBulkDeleteBtn.addEventListener('click', function() {
        const selectedCheckboxes = document.querySelectorAll('.account-checkbox:checked');
        const accountIds = Array.from(selectedCheckboxes).map(checkbox => 
          checkbox.getAttribute('data-account-id')
        );

        if (accountIds.length === 0) {
          return;
        }

        // Disable button and show loading
        this.disabled = true;
        this.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Deleting...';

        // Send bulk delete request
        fetch('/shopee-accounts/bulk-delete', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ accountIds: accountIds })
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            // Close modal and refresh page
            bulkDeleteModal.hide();
            window.location.reload();
          } else {
            alert('Error: ' + data.message);
            // Re-enable button
            this.disabled = false;
            this.innerHTML = 'Delete Selected Accounts';
          }
        })
        .catch(error => {
          console.error('Error:', error);
          alert('An error occurred while deleting accounts.');
          // Re-enable button
          this.disabled = false;
          this.innerHTML = 'Delete Selected Accounts';
        });
      });

      // Reset bulk delete button when modal is closed
      document.getElementById('bulkDeleteConfirmModal').addEventListener('hidden.bs.modal', function() {
        confirmBulkDeleteBtn.disabled = false;
        confirmBulkDeleteBtn.innerHTML = 'Delete Selected Accounts';
      });

    });
      // Filter products functionality
      const filterButtons = document.querySelectorAll('.filter-products');
      const filterModal = new bootstrap.Modal(document.getElementById('filterProductsModal'));
      const filterAllModal = new bootstrap.Modal(document.getElementById('filterAllAccountsModal'));
      let accountToFilter = null;

      filterButtons.forEach(button => {
        button.addEventListener('click', function() {
          accountToFilter = this.getAttribute('data-username');
          document.getElementById('filterAccountName').textContent = accountToFilter;
          document.getElementById('filterResults').innerHTML = '';
          document.getElementById('filterProgress').classList.add('d-none');
          document.getElementById('filterProgress').querySelector('.progress-bar').style.width = '0%';
          filterModal.show();
        });
      });

      // Confirm filter button
      document.getElementById('confirmFilter').addEventListener('click', function() {
        if (accountToFilter) {
          // Show progress bar
          const progressBar = document.getElementById('filterProgress');
          progressBar.classList.remove('d-none');
          progressBar.querySelector('.progress-bar').style.width = '50%';

          // Disable confirm button
          this.disabled = true;
          this.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Filtering...';

          // Send filter request
          fetch(`/shopee-accounts/filter-products/${accountToFilter}`, {
              method: 'GET',
              headers: {
                'Content-Type': 'application/json'
              }
            })
            .then(response => response.json())
            .then(data => {
              // Update progress bar
              progressBar.querySelector('.progress-bar').style.width = '100%';

              // Re-enable confirm button
              document.getElementById('confirmFilter').disabled = false;
              document.getElementById('confirmFilter').innerHTML = 'Filter Products';

              if (data.success) {
                // Show results
                const resultsDiv = document.getElementById('filterResults');
                resultsDiv.innerHTML = `
                                <div class="alert alert-success">
                                    <h5>Filtering completed successfully!</h5>
                                    <ul>
                                        <li>updated products: ${data.stats.updatedCount}</li>
                                    
                                    </ul>
                                </div>
                            `;

                // Add refresh button
                resultsDiv.innerHTML += `
                                <button class="btn btn-primary" onclick="window.location.reload()">
                                    <i class="fas fa-sync"></i> Refresh Page
                                </button>
                            `;
              } else {
                // Show error
                document.getElementById('filterResults').innerHTML = `
                                <div class="alert alert-danger">
                                    <h5>Error:</h5>
                                    <p>${data.message}</p>
                                </div>
                            `;
              }
            })
            .catch(error => {
              console.error('Error:', error);

              // Re-enable confirm button
              document.getElementById('confirmFilter').disabled = false;
              document.getElementById('confirmFilter').innerHTML = 'Filter Products';

              // Show error
              document.getElementById('filterResults').innerHTML = `
                            <div class="alert alert-danger">
                                <h5>Error:</h5>
                                <p>An error occurred while filtering products.</p>
                            </div>
                        `;
            });
        }
      });

      // Filter All Accounts functionality
      document.getElementById('confirmFilterAll').addEventListener('click', function() {
        // Get all visible accounts
        const visibleRows = Array.from(document.querySelectorAll('tbody tr')).filter(row => {
          return row.style.display !== 'none';
        });

        if (visibleRows.length === 0) {
          document.getElementById('filterAllResults').innerHTML = `
                        <div class="alert alert-warning">
                            <p>No visible accounts found. Please adjust your filters.</p>
                        </div>
                    `;
          return;
        }

        // Show progress bar
        const progressBar = document.getElementById('filterAllProgress');
        progressBar.classList.remove('d-none');
        progressBar.querySelector('.progress-bar').style.width = '10%';

        // Disable confirm button
        this.disabled = true;
        this.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Filtering All Accounts...';

        // Get usernames from visible rows
        // Xác định index cột username từ header
        const headerCells = document.querySelectorAll('thead th');
        const usernameIndex = Array.from(headerCells).findIndex(cell => cell.textContent.includes('Username'));

        const usernames = visibleRows.map(row => {
          const usernameCell = row.cells[usernameIndex];
          return usernameCell ? usernameCell.textContent.trim() : '';
        }).filter(username => username && username !== 'N/A');

        // Results container
        const resultsDiv = document.getElementById('filterAllResults');
        resultsDiv.innerHTML = `
                    <div class="alert alert-info">
                        <p>Starting to filter ${usernames.length} accounts...</p>
                    </div>
                `;

        // Process accounts sequentially
        let processed = 0;
        let successful = 0;
        let failed = 0;
        let totalResults = {};

        // Function to process each account
        const processAccount = (index) => {
          if (index >= usernames.length) {
            // All accounts processed
            progressBar.querySelector('.progress-bar').style.width = '100%';

            // Re-enable confirm button
            document.getElementById('confirmFilterAll').disabled = false;
            document.getElementById('confirmFilterAll').innerHTML = 'Filter All Accounts';

            // Show final results
            resultsDiv.innerHTML = `
                            <div class="alert ${failed > 0 ? 'alert-warning' : 'alert-success'}">
                                <h5>Filtering completed!</h5>
                                <p>Processed ${usernames.length} accounts: ${successful} successful, ${failed} failed</p>
                                ${totalResults.initialCount ? `
                                <ul>
                                    <li>Total products: ${totalResults.initialCount}</li>
                                </ul>` : ''}
                            </div>
                        `;

            // Add refresh button
            resultsDiv.innerHTML += `
                            <button class="btn btn-primary" onclick="window.location.reload()">
                                <i class="fas fa-sync"></i> Refresh Page
                            </button>
                        `;
            return;
          }

          const username = usernames[index];
          const progress = Math.floor(10 + ((index + 1) / usernames.length) * 90);
          progressBar.querySelector('.progress-bar').style.width = `${progress}%`;

          // Update status
          resultsDiv.innerHTML = `
                        <div class="alert alert-info">
                            <p>Processing account ${index + 1}/${usernames.length}: ${username}</p>
                            <p>Completed: ${successful} successful, ${failed} failed</p>
                        </div>
                    `;

          // Send filter request for this account
          fetch(`/shopee-accounts/filter-products/${username}`, {
              method: 'GET',
              headers: {
                'Content-Type': 'application/json'
              }
            })
            .then(response => response.json())
            .then(data => {
              processed++;

              if (data.success) {
                successful++;

                // Aggregate stats
                if (!totalResults.initialCount) {
                  totalResults = {
                    initialCount: 0,
                    unlinkedCount: 0,
                    newProductsAdded: 0,
                    finalCount: 0
                  };
                }

                totalResults.initialCount += data.stats.initialCount || 0;
                totalResults.unlinkedCount += data.stats.unlinkedCount || 0;
                totalResults.newProductsAdded += data.stats.newProductsAdded || 0;
                totalResults.finalCount += data.stats.finalCount || 0;
              } else {
                failed++;
              }

              // Process next account
              processAccount(index + 1);
            })
            .catch(error => {
              console.error(`Error filtering account ${username}:`, error);
              processed++;
              failed++;

              // Process next account
              processAccount(index + 1);
            });
        };

        // Start processing accounts
        processAccount(0);
      });

      // Filter by team
      const teamFilter = document.getElementById('teamFilter');
      if (teamFilter) {
        teamFilter.addEventListener('change', function() {
          const selectedTeam = this.value;
          const tableRows = document.querySelectorAll('tbody tr');

          tableRows.forEach(row => {
            const team = row.cells[4].textContent.trim();

            if (selectedTeam === '' || team === selectedTeam || (team === 'N/A' && selectedTeam === 'null')) {
              row.style.display = '';
            } else {
              row.style.display = 'none';
            }
          });
        });
      }

      // Filter by status
      const statusFilter = document.getElementById('statusFilter');
      if (statusFilter) {
        statusFilter.addEventListener('change', function() {
          const selectedStatus = this.value;
          const tableRows = document.querySelectorAll('tbody tr');

          tableRows.forEach(row => {
            const statusCell = row.cells[5].querySelector('.badge');
            const isActive = statusCell.classList.contains('bg-success');

            if (selectedStatus === '' || (selectedStatus === 'true' && isActive) || (selectedStatus === 'false' && !isActive)) {
              row.style.display = '';
            } else {
              row.style.display = 'none';
            }
          });
        });
      }

      // Edit account functionality
      const editButtons = document.querySelectorAll('.edit-account');
      const editForm = document.getElementById('editAccountForm');

      editButtons.forEach(button => {
        button.addEventListener('click', function() {
          const accountId = this.getAttribute('data-id');
          const username = this.getAttribute('data-username');
          const email = this.getAttribute('data-email');
          const phone = this.getAttribute('data-phone');
          const shopId = this.getAttribute('data-shop-id');
          const team = this.getAttribute('data-team');
          const isActive = this.getAttribute('data-is-active') === 'true';
          const isMcn = this.getAttribute('data-is-mcn') === 'true'; // Get isMcn value
          // Set form action
          editForm.action = `/shopee-accounts/update/${accountId}`;

          // Populate form fields
          document.getElementById('edit_username').value = username || '';
          document.getElementById('edit_email').value = email || '';
          document.getElementById('edit_phone').value = phone || '';
          document.getElementById('edit_shop_id').value = shopId || '';

          // Set team if the select exists
          const teamSelect = document.getElementById('edit_team');
          if (teamSelect && team) {
            teamSelect.value = team;
          }
          document.getElementById('edit_isMcn').checked = isMcn; // Set isMcn checkbox
          document.getElementById('edit_is_active').checked = isActive;
        });
      });

      // Function to apply filters
      window.applyFilters = function() {
        const teamFilter = document.getElementById('teamFilter');
        const statusFilter = document.getElementById('statusFilter');
        const searchInput = document.getElementById('searchInput');
        const searchForm = document.getElementById('searchForm');

        // Add team filter to form if it exists
        if (teamFilter) {
          let teamInput = searchForm.querySelector('input[name="team"]');
          if (!teamInput && teamFilter.value) {
            teamInput = document.createElement('input');
            teamInput.type = 'hidden';
            teamInput.name = 'team';
            searchForm.appendChild(teamInput);
          }

          if (teamInput) {
            if (teamFilter.value) {
              teamInput.value = teamFilter.value;
            } else {
              teamInput.remove();
            }
          }
        }

        // Add status filter to form if selected
        if (statusFilter.value) {
          let statusInput = searchForm.querySelector('input[name="status"]');
          if (!statusInput) {
            statusInput = document.createElement('input');
            statusInput.type = 'hidden';
            statusInput.name = 'status';
            searchForm.appendChild(statusInput);
          }
          statusInput.value = statusFilter.value;
        } else {
          const statusInput = searchForm.querySelector('input[name="status"]');
          if (statusInput) {
            statusInput.remove();
          }
        }

        // Submit the form
        searchForm.submit();
      };

      // Device Info functionality
      const deviceInfoButtons = document.querySelectorAll('.get-device-info');
      const deviceInfoModal = new bootstrap.Modal(document.getElementById('deviceInfoModal'));
      let countries = [];
      let brands = [];


      // Lấy danh sách quốc gia và thương hiệu khi trang được tải
      fetch('/shopee-accounts/list_info', {
          method: 'GET',
          headers: {
            'Content-Type': 'application/json'
          }
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            countries = data.countries || [];
            brands = data.brands || [];

            // Populate country select
            const countrySelect = document.getElementById('countrySelect');
            if (countries.length > 0) {
              // Xóa các option cũ trừ option đầu tiên
              while (countrySelect.options.length > 1) {
                countrySelect.remove(1);
              }

              // Thêm các option mới
              countries.forEach(country => {
                const option = document.createElement('option');
                option.value = country.iso2;
                option.textContent = country.name;
                // Set PH as default selected country
                if (country.iso2 === 'PH') {
                  option.selected = true;
                }
                countrySelect.appendChild(option);
              });
            }

            // Populate brand select
            const brandSelect = document.getElementById('brandSelect');
            if (brands.length > 0) {
              // Xóa các option cũ trừ option đầu tiên
              while (brandSelect.options.length > 1) {
                brandSelect.remove(1);
              }

              // Thêm các option mới
              brands.forEach(brand => {
                const option = document.createElement('option');
                option.value = brand;
                option.textContent = brand;
                if (brand === 'samsung') {
                  option.selected = true;
                }
                brandSelect.appendChild(option);
              });
            }

            // Cập nhật Select2 sau khi thêm options
            $('#countrySelect').trigger('change');
            $('#brandSelect').trigger('change');

          } else {
            console.error('Không thể lấy danh sách quốc gia và thương hiệu:', data.message);
          }
        })
        .catch(error => {
          console.error('Lỗi khi lấy danh sách quốc gia và thương hiệu:', error);
        });

      // Xử lý sự kiện khi nhấn nút lấy thông tin thiết bị
      deviceInfoButtons.forEach(button => {
        button.addEventListener('click', function() {
          const username = this.getAttribute('data-username');

          // Set username in modal title
          document.getElementById('deviceInfoUsername').textContent = username;

          // Show loading state
          document.getElementById('deviceInfoLoading').style.display = 'block';
          document.getElementById('deviceInfoError').style.display = 'none';
          document.getElementById('deviceInfoContent').style.display = 'none';
          document.getElementById('deviceSelectors').style.display = 'none';

          // Show modal
          deviceInfoModal.show();

          // Fetch device info from server
          fetchDeviceInfo(username);
        });
      });

      // Xử lý sự kiện khi nhấn nút tạo thiết bị mới
      document.getElementById('generateDeviceBtn').addEventListener('click', function() {
        const username = document.getElementById('deviceInfoUsername').textContent;
        const country = document.getElementById('countrySelect').value;
        const brand = document.getElementById('brandSelect').value;

        fetchDeviceInfo(username, country, brand);
      });

      // Hàm để lấy thông tin thiết bị
      function fetchDeviceInfo(username, country = '', brand = '') {
        // Show loading state
        document.getElementById('deviceInfoLoading').style.display = 'block';
        document.getElementById('deviceInfoError').style.display = 'none';
        document.getElementById('deviceInfoContent').style.display = 'none';

        // Tạo query params
        const params = new URLSearchParams();
        if (country) {
          params.append('country', country);
          params.append('is_new', 1);
        }

        if (username) params.append('username', username);
        if (brand) params.append('brand_device', brand);

        // Fetch device info from /random-device endpoint
        fetch(`/shopee-accounts/random-device?${params.toString()}`, {
            method: 'GET',
            headers: {
              'Content-Type': 'application/json'
            }
          })
          .then(response => response.json())
          .then(data => {
            // Hide loading
            document.getElementById('deviceInfoLoading').style.display = 'none';

            if (data.success) {
              // Show selectors and content
              document.getElementById('deviceSelectors').style.display = 'block';
              document.getElementById('deviceInfoContent').style.display = 'block';

              // Set device info and change background to green if exists
              const deviceInfoElement = document.getElementById('deviceInfoJson');
              deviceInfoElement.textContent = data.deviceInfo;
              if (data.deviceInfo) {
                deviceInfoElement.style.backgroundColor = '#e8f5e9';
              }
            } else {
              // Show error
              document.getElementById('deviceInfoError').style.display = 'block';
              document.getElementById('deviceInfoError').style.backgroundColor = '#e8f5e9';
              document.getElementById('deviceInfoError').textContent = data.message || 'Không thể lấy thông tin thiết bị';
            }
          })
          .catch(error => {
            // Hide loading and show error
            document.getElementById('deviceInfoLoading').style.display = 'none';
            document.getElementById('deviceInfoError').style.display = 'block';
            document.getElementById('deviceInfoError').textContent = 'Lỗi khi lấy thông tin thiết bị: ' + error.message;
          });
      }

      // Copy device info to clipboard
      document.getElementById('copyDeviceInfo').addEventListener('click', function() {
        const deviceInfo = document.getElementById('deviceInfoJson').textContent;
        navigator.clipboard.writeText(deviceInfo)
          .then(() => {
            // Show success message or toast
            alert('Đã sao chép thông tin thiết bị vào clipboard!');
          })
          .catch(err => {
            console.error('Không thể sao chép: ', err);
          });
      });

      // Delete account functionality
      const deleteButtons = document.querySelectorAll('.delete-account');
      const deleteModal = new bootstrap.Modal(document.getElementById('deleteConfirmModal'));
      let accountToDelete = null;

      deleteButtons.forEach(button => {
        button.addEventListener('click', function() {
