        <h5 class="modal-title">Thêm tài khoản</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div id="addAccountFeedback" class="alert d-none mb-3" role="alert"></div>
        <div class="mb-3">
          <label for="addAccountUsernameInput" class="form-label">Tên đăng nhập</label>
          <input id="addAccountUsernameInput" type="text" class="form-control" placeholder="Nhập tên đăng nhập">
        </div>
        <div class="mb-0">
          <label for="addAccountCookieInput" class="form-label">Cookie Live</label>
          <textarea id="addAccountCookieInput" class="form-control" rows="5"
            placeholder="Dán cookie vào đây..."></textarea>
          <small class="text-muted">Hệ thống sẽ tự parse `SPC_U` để lấy `user_id`.</small>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
        <button type="button" class="btn btn-primary" id="submitAddAccountBtn">Thêm tài khoản</button>
      </div>
    </div>
  </div>
</div>
<div class="modal fade" id="bulkProxyModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Cập nhật Proxy hàng loạt</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div id="bulkProxyFeedback" class="alert d-none mb-3" role="alert"></div>
        <div class="mb-2 text-muted small">
          Đã chọn <strong id="bulkProxySelectedCount">0</strong> account.
          Nhập 1 proxy để áp dụng cho tất cả, hoặc nhập nhiều dòng bằng đúng số account đã chọn.
        </div>
        <div class="mb-0">
          <label for="bulkProxyInput" class="form-label">Danh sách proxy</label>
          <textarea id="bulkProxyInput" class="form-control" rows="8"
            placeholder="type://user:pass@ip:port&#10;type://ip:port&#10;type://ip:port:user:pass&#10;ip:port:user:pass"></textarea>
          <small class="text-muted">
            Hỗ trợ: `type://user:pass@ip:port`, `type://ip:port`, `type://ip:port:user:pass`, `ip:port:user:pass`
          </small>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
        <button type="button" class="btn btn-primary" id="submitBulkProxyBtn">Cập nhật Proxy</button>
      </div>
    </div>
  </div>
</div>
<div class="modal fade campaign-fullscreen-modal" id="campaignCreateModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-fullscreen modal-dialog-scrollable campaign-create-fullscreen-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Tạo chiến dịch mới</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="row g-2 mb-3">
          <div class="col-md-4">
            <label class="form-label mb-1" for="campaignNameInput">Tên chiến dịch</label>
            <input type="text" class="form-control form-control-sm" id="campaignNameInput"
              placeholder="Tên chiến dịch ...">
          </div>
          <div class="col-md-2">
            <label class="form-label mb-1" for="campaignDelayMinInput">Độ trễ tối thiểu</label>
            <input type="number" class="form-control form-control-sm" id="campaignDelayMinInput" min="0" step="1"
              value="10">
          </div>
          <div class="col-md-2">
            <label class="form-label mb-1" for="campaignDelayMaxInput">Độ trễ tối đa</label>
            <input type="number" class="form-control form-control-sm" id="campaignDelayMaxInput" min="0" step="1"
              value="30">
          </div>
          <div class="col-md-4 d-flex align-items-end">
            <div class="d-flex flex-wrap gap-2">
              <button class="btn btn-sm btn-warning" id="campaignModalUploadExcelReupBtn" type="button">
                <i class="fas fa-upload me-1"></i>Tải lên excel Reup
              </button>
              <input type="file" id="campaignModalUploadExcelReupInput" accept=".xlsx,.xls" class="d-none">
              <button class="btn btn-sm btn-info text-white" id="campaignModalUploadExcelAiBtn" type="button">
                <i class="fas fa-upload me-1"></i>Tải lên excel AI
              </button>
              <input type="file" id="campaignModalUploadExcelAiInput" accept=".xlsx,.xls" class="d-none">
              <button class="btn btn-sm btn-primary" id="campaignModalUploadExcelBtn" type="button">
                <i class="fas fa-upload me-1"></i>Tải lên excel
              </button>
              <input type="file" id="campaignModalUploadExcelInput" accept=".xlsx,.xls" class="d-none">
              <button class="btn btn-sm btn-success" id="campaignModalDownloadTemplateBtn" type="button">
                <i class="fas fa-file-excel me-1"></i>Tải template
              </button>
              <button class="btn btn-sm btn-outline-secondary" id="campaignModalRefreshVideosBtn" type="button">
                <i class="fas fa-rotate-right me-1"></i>Tải lại
              </button>
            </div>
          </div>
        </div>

        <div class="alert d-none" id="campaignModalMessage" role="alert"></div>

        <div class="card mb-3">
          <div class="card-body py-2">

            <div class="row g-2 align-items-center">
              <div class="col-md-4">
                <label class="form-label mb-1" for="campaignModalSearchKeyword">Tìm kiếm</label>
                <input type="text" id="campaignModalSearchKeyword" class="form-control form-control-sm"
                  placeholder="path_video, name_file, id_hash...">
              </div>
              <div class="col-md-3">
                <label class="form-label mb-1" for="campaignModalStatusFilter">Trạng thái thông tin</label>
                <select id="campaignModalStatusFilter" class="form-select form-select-sm">
                  <option value="all">Tất cả</option>
                  <option value="missing">Chưa đủ thông tin cần update</option>
                  <option value="completed">Đã có đủ thông tin</option>
                </select>
              </div>
              <div class="col-md-3">
                <label class="form-label mb-1" for="campaignModalUploadFilter">Trạng thái upload</label>
                <select id="campaignModalUploadFilter" class="form-select form-select-sm">
                  <option value="all">Tất cả</option>
                  <option value="VIDEO_UPLOADED">Đã upload</option>
                  <option value="NOT_UPLOADED">Chưa upload</option>
                </select>
              </div>
              <div class="col-md-2">
                <div class="form-check mt-4">
                  <input class="form-check-input" type="checkbox" id="campaignModalOnlyFolder">
                  <label class="form-check-label" for="campaignModalOnlyFolder">Chỉ lấy theo thư mục cài đặt</label>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="alert alert-info py-2 mb-3" role="alert">
          <i class="fas fa-circle-info me-1"></i>
          Sau khi <strong>Tạo và chạy chiến dịch</strong>, chiến dịch sẽ vào hàng đợi và tự xử lý tuần tự.
          Chỉ khi chiến dịch bị lỗi thì mới cần dùng nút <strong>Bắt đầu</strong> hoặc <strong>Dừng</strong> ở chiến
          dịch đó.
        </div>

        <div class="table-responsive">
          <table class="table table-striped table-hover align-middle mb-0" id="campaignModalVideosTable">
            <thead class="table-light">
              <tr>
                <th class="text-center"><input type="checkbox" id="campaignModalSelectAllVideos"></th>
                <th>#</th>
                <th>Trạng thái thông tin</th>
                <th>Đường dẫn Video</th>
                <th>ID</th>
                <th>Tên file</th>
                <th>Liên kết</th>
                <th>Tài khoản</th>
                <th>Trạng thái</th>
                <th>Mô tả</th>
                <th>Hashtag</th>
                <th>Thiếu field</th>
              </tr>
            </thead>
            <tbody id="campaignModalVideosTableBody">
              <tr>
                <td colspan="12" class="text-center py-4 text-muted">Đang tải dữ liệu...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
      <div class="modal-footer d-flex justify-content-between">
        <div class="small text-muted">Đã chọn: <strong id="campaignModalSelectedCount">0</strong> videos</div>
        <div>
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
          <button type="button" class="btn btn-primary" id="campaignModalCreateAndStartBtn">
            <i class="fas fa-play me-1"></i>Tạo và chạy chiến dịch
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .container-fluid.px-0 {
    padding-left: 0 !important;
    padding-right: 0 !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    max-width: none !important;
  }

  #videoManagerTabs {
    margin: auto !important;
    width: 100% !important;
  }

  #videoManagerTabsContent {
    width: 100% !important;
    max-width: none !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
  }

  #videoManagerTabsContent > .tab-pane {
    width: 100% !important;
    max-width: none !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
  }

  #videoManagerTabsContent > .tab-pane > .row,
  #videoManagerTabsContent > .tab-pane > .w-100,
  #videoManagerTabsContent > .tab-pane > .container,
  #videoManagerTabsContent > .tab-pane > .container-fluid {
    width: 100% !important;
    max-width: none !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
  }

  #localServiceError,
  #websocketServiceError {
    width: 100% !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
  }

  #videos-tab-pane {
    font-weight: 600;
  }

  #videos-tab-pane>.row.g-2.mb-3 {
    font-weight: 700;
  }

  #settings-tab-pane>.card>.card-body {
    font-weight: 700;
  }

  #localSettingsForm {
    font-weight: 700;
  }

  #serverAccessTokenInput {
    font-weight: 600;
  }

  #settingPathFolderInput {
    font-weight: 600;
  }

  #videosTable th:nth-child(4),
  #videosTable th:nth-child(5),
  #videosTable td:nth-child(4),
  #videosTable td:nth-child(5) {
    display: none;
  }

  #campaignModalVideosTable th:nth-child(4),
  #campaignModalVideosTable th:nth-child(5),
  #campaignModalVideosTable td:nth-child(4),
  #campaignModalVideosTable td:nth-child(5) {
    display: none;
  }

  #campaignModalVideosTable.path-only th:nth-child(n + 5),
  #campaignModalVideosTable.path-only td:nth-child(n + 5) {
    display: none;
  }

  .campaign-create-modal-dialog {
    max-width: min(96vw, 1700px);
  }

  .campaign-header-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
    max-width: 100%;
    min-width: 0;
  }

  .campaign-header-actions .btn {
    white-space: normal;
  }

  #campaigns-tab-pane .card-header {
    flex-wrap: wrap;
    gap: 8px;
    overflow-x: hidden;
  }

  #campaigns-tab-pane .card-header>strong {
    min-width: 0;
  }

  @media (max-width: 768px) {
    #campaigns-tab-pane .card-header {
      flex-direction: column;
      align-items: flex-start !important;
      gap: 8px;
    }

    .campaign-header-actions {
      width: 100%;
      justify-content: flex-start;
    }
  }

  .campaign-fullscreen-modal .modal-dialog {
    margin: 0;
    transform: translateY(-100%);
    transition: transform 0.28s ease-out;
  }

  .campaign-fullscreen-modal.show .modal-dialog {
    transform: translateY(0);
  }

  .campaign-fullscreen-modal .modal-content {
    border: 0;
    border-radius: 0;
    min-height: 100vh;
  }

  .campaign-progress-metrics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
  }

  .campaign-metric-card {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #fff;
    border: 1px solid #e6eaf0;
    border-radius: 10px;
    padding: 8px 10px;
  }

  .campaign-metric-icon {
    width: 26px;
    height: 26px;
    border-radius: 8px;
    background: #f3f6fb;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
  }

  .campaign-metric-label {
    font-size: 11px;
    color: #6b7280;
    line-height: 1.1;
  }

  .campaign-metric-value {
    font-size: 14px;
    font-weight: 700;
    color: #1f2937;
    line-height: 1.2;
  }

  .campaign-progress-track {
    height: 16px;
    border-radius: 0;
    background-color: #edf0f3;
    overflow: hidden;
  }

  .campaign-progress-fill {
    border-radius: 0;
    background-color: #0d6efd !important;
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    line-height: 16px;
    text-align: center;
    white-space: nowrap;
    transition: width 0.25s ease;
  }

  #campaignJobsTable {
    border-collapse: separate;
    border-spacing: 0;
  }

  #campaignJobsTable thead th {
    position: sticky;
    top: 0;
    z-index: 2;
    background: #f8f9fa;
    box-shadow: inset 0 -1px 0 #dee2e6;
  }
</style>

