<div class="container-fluid">
  <h1 class="mb-4"><%= user._id ? 'Chỉnh sửa tài khoản' : 'Tạo tài khoản mới' %></h1>
  
  <div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-8 col-xl-7">
      <div class="card">
        <div class="card-body">
      <form id="userForm" method="POST" action="<%= user._id ? `/admin/accounts/${user._id}` : '/admin/accounts' %>">
        <% const isEdit = !!user._id; %>
        <% if (user._id) { %>
          <input type="hidden" name="_method" value="PUT">
        <% } %>
        
        <div class="mb-3">
          <label for="username" class="form-label">Username</label>
          <input type="text" class="form-control" id="username" name="username" value="<%= user.username || '' %>" required <%= user._id ? 'readonly' : '' %>>
          <% if (user._id) { %>
            <small class="text-muted">Username không thể thay đổi sau khi tạo</small>
          <% } %>
        </div>
        
        <div class="mb-3">
          <label for="password" class="form-label"><%= user._id ? 'Mật khẩu mới (để trống nếu không đổi)' : 'Mật khẩu' %></label>
          <input type="password" class="form-control" id="password" name="password" <%= !user._id ? 'required' : '' %>>
        </div>
        
        <div class="mb-3">
          <label for="role" class="form-label">Vai trò</label>
          <select class="form-select" id="role" name="role" required>
            <option value="user" <%= user.role === 'user' ? 'selected' : '' %>>User</option>
            <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>Admin</option>
          </select>
        </div>
        
        <div class="mb-3">
          <label for="teamMode" class="form-label">Team</label>
          <select class="form-select" id="teamMode" name="teamMode">
            <option value="create_by_username" <%= !isEdit ? 'selected' : '' %>>Tạo team mới theo username (mặc định)</option>
            <option value="select_existing" <%= (isEdit && user.team) ? 'selected' : '' %>>Chọn team có sẵn</option>
            <option value="none" <%= (isEdit && !user.team) ? 'selected' : '' %>>Không gán team</option>
          </select>
        </div>

        <div class="mb-3" id="teamNameWrapper">
          <label for="teamName" class="form-label">Tên team mới</label>
          <input type="text" class="form-control" id="teamName" name="teamName" value="<%= user.username || '' %>" readonly>
          <small class="text-muted">Tên team sẽ tự động lấy theo username đã nhập</small>
        </div>

        <div class="mb-3" id="teamSelectWrapper">
          <label for="team" class="form-label">Chọn team có sẵn</label>
          <select class="form-select" id="team" name="team">
            <option value="">-- Chọn team --</option>
            <% teams.forEach(team => { %>
              <option value="<%= team._id %>" <%= user.team && user.team._id.toString() === team._id.toString() ? 'selected' : '' %>><%= team.name %></option>
            <% }); %>
          </select>
          <small class="text-muted">User chỉ có thể xem dữ liệu của team được chỉ định</small>
        </div>

        <div class="mb-3">
          <label for="expiredAt" class="form-label">Thời gian hết hạn</label>
          <input
            type="datetime-local"
            class="form-control"
            id="expiredAt"
            name="expiredAt"
            value="<%= user.expiredAt ? new Date(user.expiredAt.getTime() - user.expiredAt.getTimezoneOffset() * 60000).toISOString().slice(0, 16) : '' %>"
          >
          <small class="text-muted">Để trống nếu tài khoản không giới hạn thời gian</small>
        </div>
        
        <div class="d-flex justify-content-between">
          <a href="/admin/accounts" class="btn btn-secondary">Hủy</a>
          <button type="submit" class="btn btn-primary">Lưu</button>
        </div>
      </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const userForm = document.getElementById('userForm');
    const usernameInput = document.getElementById('username');
    const teamModeSelect = document.getElementById('teamMode');
    const teamNameInput = document.getElementById('teamName');
    const teamNameWrapper = document.getElementById('teamNameWrapper');
    const teamSelectWrapper = document.getElementById('teamSelectWrapper');
    const teamSelect = document.getElementById('team');

    function syncTeamNameFromUsername() {
      if (!teamNameInput || !usernameInput) return;
      teamNameInput.value = (usernameInput.value || '').trim();
    }

    function toggleTeamMode() {
      if (!teamModeSelect || !teamNameWrapper || !teamSelectWrapper || !teamNameInput || !teamSelect) return;
      const mode = teamModeSelect.value;
      const isCreateByUsername = mode === 'create_by_username';
      const isSelectExisting = mode === 'select_existing';

      teamNameWrapper.classList.toggle('d-none', !isCreateByUsername);
      teamNameInput.disabled = !isCreateByUsername;
      if (isCreateByUsername) {
        syncTeamNameFromUsername();
      }

      teamSelectWrapper.classList.toggle('d-none', !isSelectExisting);
      teamSelect.disabled = !isSelectExisting;
      if (!isSelectExisting) {
        teamSelect.value = '';
      }
    }

    if (usernameInput) {
      usernameInput.addEventListener('input', syncTeamNameFromUsername);
      syncTeamNameFromUsername();
    }
    if (teamModeSelect) {
      teamModeSelect.addEventListener('change', toggleTeamMode);
      toggleTeamMode();
    }
    
    userForm.addEventListener('submit', function(e) {
      e.preventDefault();
      
      const formData = new FormData(userForm);
      const data = {};
      
      formData.forEach((value, key) => {
        // Skip empty password field for edit
        if (key === 'password' && value === '' && userForm.getAttribute('action').includes('/')) {
          return;
        }
        data[key] = value;
      });
      
      // Handle PUT method
      let method = 'POST';
      if (formData.get('_method') === 'PUT') {
        method = 'PUT';
      }
      
      fetch(userForm.getAttribute('action'), {
        method: method,
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          alert(method === 'POST' ? 'Tạo tài khoản thành công' : 'Cập nhật tài khoản thành công');
          window.location.href = '/admin/accounts';
        } else {
          alert('Lỗi: ' + data.message);
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('Đã xảy ra lỗi khi lưu tài khoản');
      });
    });
  });
</script>
