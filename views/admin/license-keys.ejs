<div class="container-fluid">
  <h1 class="mb-4">Quản lý License Keys</h1>
  
  <div class="mb-3">
    <a href="/admin/license-keys/new" class="btn btn-success">
      <i class="fas fa-plus"></i> Tạo license mới
    </a>
  </div>
  
  <div class="card">
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-striped table-hover">
          <thead>
            <tr>
              <th>Key</th>
              <th>Quyền tool</th>
              <th>Roles</th>
              <th>Ngày tạo</th>
              <th>Ngày hết hạn</th>
              <th>Ghi chú</th>
              <th>Thao tác</th>
            </tr>
          </thead>
          <tbody>
            <% licenses.forEach(lic => { %>
              <tr>
                <td><code><%= lic.key %></code></td>
                <td>
                  <span class="badge <%= lic.scopes?.check_product ? 'bg-primary' : 'bg-secondary' %>">check_product</span>
                  <span class="badge <%= lic.scopes?.create_video ? 'bg-primary' : 'bg-secondary' %>">create_video</span>
                  <span class="badge <%= lic.scopes?.upload_video ? 'bg-primary' : 'bg-secondary' %>">upload_video</span>
                </td>
                <td><%= (lic.roles || []).join(', ') %></td>
                <td><%= new Date(lic.createdAt).toLocaleString('vi-VN') %></td>
                <td><%= new Date(lic.expiresAt).toLocaleDateString('vi-VN') %></td>
                <td><%= lic.note || '' %></td>
                <td>
                  <a href="/admin/license-keys/<%= lic._id %>/edit" class="btn btn-sm btn-primary">Sửa</a>
                  <button class="btn btn-sm btn-danger delete-license" data-id="<%= lic._id %>">Xóa</button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const deleteButtons = document.querySelectorAll('.delete-license');
    deleteButtons.forEach(btn => {
      btn.addEventListener('click', function() {
        const id = this.getAttribute('data-id');
        if (confirm('Bạn có chắc chắn muốn xóa license này?')) {
          fetch(`/admin/license-keys/${id}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' }
          })
          .then(r => r.json())
          .then(d => {
            if (d.success) {
              alert('Xóa license thành công');
              window.location.reload();
            } else {
              alert('Lỗi: ' + d.message);
            }
          })
          .catch(err => {
            console.error('Error:', err);
            alert('Đã xảy ra lỗi khi xóa license');
          });
        }
      });
    });
  });
</script>

